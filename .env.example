# PostgreSQL
POSTGRES_PASSWORD=changeme

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Temp directory for export/backup files
TEMP_DIR=/tmp/mongovis

# Timezone for cron expressions (backup schedules, sync jobs).
# Times you enter in the UI are interpreted in this timezone.
# Examples: UTC | Asia/Kolkata | America/New_York | Europe/London
SCHEDULER_TZ=UTC

# Optional: SMTP for alert email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@yourapp.com
