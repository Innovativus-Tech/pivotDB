# PostgreSQL
POSTGRES_PASSWORD=changeme

# Encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Temp directory for export/backup files
TEMP_DIR=/tmp/mongovis

# Optional: SMTP for alert email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@yourapp.com
