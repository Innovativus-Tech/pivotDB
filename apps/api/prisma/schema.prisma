generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Connection {
  id             String   @id @default(cuid())
  name           String
  encryptedUri   String
  topology       String
  tags           String[]
  readOnly       Boolean  @default(false)
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  s3Destinations  S3Destination[]
  backupJobs      BackupJob[]
  syncJobsSource  SyncJob[]     @relation("SyncSource")
  syncJobsDest    SyncJob[]     @relation("SyncDest")
  exportJobs      ExportJob[]
  alertRules      AlertRule[]
  savedQueries    SavedQuery[]
}

model S3Destination {
  id                   String      @id @default(cuid())
  connectionId         String
  connection           Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  bucket               String
  region               String
  prefix               String      @default("")
  encryptedCredentials String
  verifiedAt           DateTime?
  createdAt            DateTime    @default(now())

  backupJobs  BackupJob[]
}

model BackupJob {
  id              String        @id @default(cuid())
  connectionId    String
  connection      Connection    @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  s3DestId        String
  s3Destination   S3Destination @relation(fields: [s3DestId], references: [id])
  schedule        String
  scope           Json
  retentionPolicy Json
  enabled         Boolean       @default(true)
  createdAt       DateTime      @default(now())

  runs  JobRun[]
}

model SyncJob {
  id           String     @id @default(cuid())
  sourceConnId String
  source       Connection @relation("SyncSource", fields: [sourceConnId], references: [id], onDelete: Cascade)
  destConnId   String
  destination  Connection @relation("SyncDest",   fields: [destConnId],   references: [id], onDelete: Cascade)
  scope        Json
  writeMode    String
  schedule     String?
  transforms   Json?
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())

  runs  JobRun[]
}

model ExportJob {
  id           String     @id @default(cuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  database     String
  collection   String
  query        Json
  isPipeline   Boolean    @default(false)
  format       String
  options      Json
  destination  String?
  status       String     @default("pending")
  fileKey      String?
  createdAt    DateTime   @default(now())

  runs  JobRun[]
}

model JobRun {
  id           String    @id @default(cuid())
  jobType      String
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       String
  counts       Json?
  errorReport  Json?

  backupJobId  String?
  backupJob    BackupJob?  @relation(fields: [backupJobId], references: [id])

  syncJobId    String?
  syncJob      SyncJob?    @relation(fields: [syncJobId], references: [id])

  exportJobId  String?
  exportJob    ExportJob?  @relation(fields: [exportJobId], references: [id])
}

model AlertRule {
  id           String     @id @default(cuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  metric       String
  condition    Json
  durationSec  Int
  channels     Json
  enabled      Boolean    @default(true)
  createdAt    DateTime   @default(now())

  events  AlertEvent[]
}

model AlertEvent {
  id           String    @id @default(cuid())
  ruleId       String
  rule         AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  firedAt      DateTime  @default(now())
  resolvedAt   DateTime?
  acknowledged Boolean   @default(false)
  note         String?
}

model SavedQuery {
  id           String     @id @default(cuid())
  connectionId String
  connection   Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  name         String
  database     String
  collection   String
  query        Json
  isPipeline   Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  actor     String
  action    String
  target    String
  timestamp DateTime @default(now())
  metadata  Json?
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("viewer")
  createdAt    DateTime @default(now())
}
